# Local path to the models directory
MODEL_LOCAL_PATH=../../models

# Hugging Face Token (optional, if needing to download protected models)
# HF_TOKEN=your_token_here

# GPU Device IDs to use (e.g., "0", "0,1", "all")
CUDA_VISIBLE_DEVICES=0

# Ports
# HOST_PORT     - Port published on the host
# CONTAINER_PORT - Port bound inside the container by vLLM (also used by the healthcheck)
HOST_PORT=18000
CONTAINER_PORT=8000

# vLLM Model Configuration
# Avoid `latest`: newer images can require newer host NVIDIA drivers/CUDA.
# This tag supports Qwen3-VL on a CUDA 12.9 host. If your driver is older,
# choose a vLLM tag that supports both your driver and the selected model.
VLLM_IMAGE_TAG=v0.22.0-cu129-ubuntu2404
VLLM_MODEL_PATH=/models/sample-chat-small
VLLM_SERVED_MODEL_NAME=local/sample-chat-small
VLLM_MAX_MODEL_LEN=6144
VLLM_MAX_NUM_BATCHED_TOKENS=2048
VLLM_GPU_MEMORY_UTILIZATION=0.90
VLLM_TENSOR_PARALLEL_SIZE=1
VLLM_EXTRA_ARGS=--enforce-eager

# Advanced Configuration / Debugging
NCCL_DEBUG=INFO
# NCCL_IB_DISABLE=1
# NCCL_P2P_LEVEL=SYS
# NCCL_MIN_NCHANNELS=4
# NCCL_TOPO_FILE=/dev/null
PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True
VLLM_MEMORY_PROFILER_ESTIMATE_CUDAGRAPHS=0
