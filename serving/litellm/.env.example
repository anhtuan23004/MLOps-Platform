# LiteLLM proxy image
LITELLM_IMAGE_TAG=latest

# Ports
HOST_PORT=18040
CONTAINER_PORT=4000

# Local proxy auth. Override this in serving/litellm/.env for real use.
LITELLM_MASTER_KEY=sk-local-litellm

# LiteLLM -> vLLM route on llm-net.
VLLM_API_BASE=http://vllm:8000/v1
VLLM_API_KEY=sk-local-vllm
VLLM_LITELLM_MODEL=openai/local/sample-chat-small
