# MLflow tracking server (S3 artifacts)
MLFLOW_HOST_PORT=15000
MLFLOW_IMAGE_TAG=v2.22.0
MLFLOW_S3_BUCKET=your-bucket-name
MLFLOW_TRACKING_URI=http://localhost:15000

# S3 credentials (AWS or MinIO)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
# Set for MinIO, e.g. http://minio:9000
AWS_ENDPOINT_URL=
