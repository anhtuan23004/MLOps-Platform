# MLflow tracking server — local dev stack (Postgres + MinIO)
# Production uses external Postgres + AWS S3 via release/CI-CD (see docs/product/experiment-tracking.md).

MLFLOW_HOST_PORT=15000
MLFLOW_TRACKING_URI=http://localhost:15000

# Postgres metadata backend (container hostname: postgres)
POSTGRES_USER=mlflow
POSTGRES_PASSWORD=mlflow
POSTGRES_DB=mlflow
MLFLOW_BACKEND_STORE_URI=postgresql://mlflow:mlflow@postgres:5432/mlflow

# MinIO artifact store (local dev; production uses AWS S3)
MINIO_ROOT_USER=mlops
MINIO_ROOT_PASSWORD=mlops-secret
MINIO_HOST_PORT=19000
MINIO_CONSOLE_PORT=19001
MLFLOW_S3_BUCKET=mlops-platform
MLFLOW_ARTIFACT_ROOT=s3://mlops-platform/mlflow-artifacts

# S3-compatible credentials — same values for MLflow server and DVC remote in dev
AWS_ACCESS_KEY_ID=mlops
AWS_SECRET_ACCESS_KEY=mlops-secret
AWS_DEFAULT_REGION=us-east-1
# Container-internal MinIO endpoint (MLflow server in compose)
AWS_ENDPOINT_URL=http://minio:9000
MLFLOW_S3_IGNORE_TLS=true

# Host-side clients (pipeline on VM, DVC repro): use host-reachable MinIO endpoint
# export AWS_ENDPOINT_URL=http://localhost:19000
